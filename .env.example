# Server Configuration
PORT=3000
NODE_ENV=development

# Database Connection
DATABASE_URL="mysql://user:password@localhost:3306/taskkash"

# JWT Secret — generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET="REPLACE_WITH_STRONG_RANDOM_SECRET"

# Admin Authentication
# Generate hash: node -e "const b=require('bcryptjs');b.hash('yourpassword',10).then(console.log)"
ADMIN_EMAIL="admin@taskkash.com"
ADMIN_PASSWORD_HASH="REPLACE_WITH_BCRYPT_HASH"

# App Configuration
APP_ID=taskkash_v2

# OAuth (Optional)
# OAUTH_SERVER_URL="https://your-domain.com"
# GOOGLE_CLIENT_ID="your_google_client_id"
# GOOGLE_CLIENT_SECRET="your_google_client_secret"

VITE_APP_TITLE=TASKKASH
VITE_APP_LOGO=/logos/taskkash.png

# Analytics (optional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# CORS — comma-separated list of allowed frontend origins
ALLOWED_ORIGINS="http://localhost:3000,https://yourdomain.com"
