<?xml version="1.0" encoding="UTF-8" standalone="yes"?><w:document mc:Ignorable="w14 w15 wp14" xmlns:wpc="http://schemas.microsoft.com/office/word/2010/wordprocessingCanvas" xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" xmlns:o="urn:schemas-microsoft-com:office:office" xmlns:r="http://schemas.openxmlformats.org/officeDocument/2006/relationships" xmlns:m="http://schemas.openxmlformats.org/officeDocument/2006/math" xmlns:v="urn:schemas-microsoft-com:vml" xmlns:wp14="http://schemas.microsoft.com/office/word/2010/wordprocessingDrawing" xmlns:wp="http://schemas.openxmlformats.org/drawingml/2006/wordprocessingDrawing" xmlns:w10="urn:schemas-microsoft-com:office:word" xmlns:w="http://schemas.openxmlformats.org/wordprocessingml/2006/main" xmlns:w14="http://schemas.microsoft.com/office/word/2010/wordml" xmlns:w15="http://schemas.microsoft.com/office/word/2012/wordml" xmlns:wpg="http://schemas.microsoft.com/office/word/2010/wordprocessingGroup" xmlns:wpi="http://schemas.microsoft.com/office/word/2010/wordprocessingInk" xmlns:wne="http://schemas.microsoft.com/office/word/2006/wordml" xmlns:wps="http://schemas.microsoft.com/office/word/2010/wordprocessingShape" xmlns:cx="http://schemas.microsoft.com/office/drawing/2014/chartex" xmlns:cx1="http://schemas.microsoft.com/office/drawing/2015/9/8/chartex" xmlns:cx2="http://schemas.microsoft.com/office/drawing/2015/10/21/chartex" xmlns:cx3="http://schemas.microsoft.com/office/drawing/2016/5/9/chartex" xmlns:cx4="http://schemas.microsoft.com/office/drawing/2016/5/10/chartex" xmlns:cx5="http://schemas.microsoft.com/office/drawing/2016/5/11/chartex" xmlns:cx6="http://schemas.microsoft.com/office/drawing/2016/5/12/chartex" xmlns:cx7="http://schemas.microsoft.com/office/drawing/2016/5/13/chartex" xmlns:cx8="http://schemas.microsoft.com/office/drawing/2016/5/14/chartex" xmlns:aink="http://schemas.microsoft.com/office/drawing/2016/ink" xmlns:am3d="http://schemas.microsoft.com/office/drawing/2017/model3d" xmlns:w16cex="http://schemas.microsoft.com/office/word/2018/wordml/cex" xmlns:w16cid="http://schemas.microsoft.com/office/word/2016/wordml/cid" xmlns:w16="http://schemas.microsoft.com/office/word/2018/wordml" xmlns:w16sdtdh="http://schemas.microsoft.com/office/word/2020/wordml/sdtdatahash" xmlns:w16se="http://schemas.microsoft.com/office/word/2015/wordml/symex"><w:body><w:p><w:pPr><w:pStyle w:val="Title"/><w:spacing w:after="400"/><w:jc w:val="center"/></w:pPr><w:r><w:t xml:space="preserve">TASKKASH: Strategic Revenue &amp; Commission Constitution</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200"/></w:pPr><w:r><w:t xml:space="preserve">Executive Summary</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="300"/></w:pPr><w:r><w:t xml:space="preserve">The TASKKASH revenue model is built on an innovative dual-sided commission economy. Rather than functioning as a mere marketplace broker, TASKKASH acts as an active Market Maker. The platform generates revenue by extracting a service margin from Advertisers (to access premium data, targeting, and SLAs) and extracting a liquidity margin from Users (charging for the speed of payouts). All baseline economics are localized to Egyptian Pounds (EGP).</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 1: Advertiser Tiers &amp; Capabilities</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Tier 1: Starter / Self-Serve (10% Commission)</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Target Audience: </w:t></w:r><w:r><w:t xml:space="preserve">Small/Medium Businesses, local shops.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Minimum Campaign Spend: </w:t></w:r><w:r><w:t xml:space="preserve">50,000 EGP</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Tier 2: Growth / Advanced (15% Commission)</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Target Audience: </w:t></w:r><w:r><w:t xml:space="preserve">Growing brands, regional franchises.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Minimum Campaign Spend: </w:t></w:r><w:r><w:t xml:space="preserve">130,000 EGP</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Tier 3: Precision / Pro (20% Commission)</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Target Audience: </w:t></w:r><w:r><w:t xml:space="preserve">Retail brands, offline activation agencies.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Minimum Campaign Spend: </w:t></w:r><w:r><w:t xml:space="preserve">260,000 EGP</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Tier 4: Enterprise / Managed (25%+ Commission)</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Target Audience: </w:t></w:r><w:r><w:t xml:space="preserve">Multinational corporations, Market Research Firms.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="300"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">Minimum Campaign Spend: </w:t></w:r><w:r><w:t xml:space="preserve">520,000 EGP+</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 2: Recommended Task Rewards &amp; Market Valuation Benchmarks</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Tier 1: Starter Tasks (&lt;30 seconds, Digital) - 5.00 EGP to 26.00 EGP range</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Tier 2: Growth Tasks (3-5 minutes) - 39.00 EGP to 104.00 EGP range</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Tier 3: Precision Tasks (Physical Effort / High Time) - 150.00 EGP to 520.00 EGP range</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/><w:spacing w:after="300"/></w:pPr><w:r><w:t xml:space="preserve">Tier 4: Enterprise Tasks (B2B Asset Creation) - 520.00 EGP to 2,600.00 EGP range</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 3: User Progression &amp; Verification Economy</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Level 1: Novice / Basic Player</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="150"/></w:pPr><w:r><w:t xml:space="preserve">Requires 5 Quick Tasks. strictly capped at taking tasks worth less than 50.00 EGP.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Level 2: Verified Contributor</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="150"/></w:pPr><w:r><w:t xml:space="preserve">Requires Phone Verification + 15 Tasks.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">Level 3: Elite Field Agent</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="300"/></w:pPr><w:r><w:t xml:space="preserve">Requires strict National ID Verification. Unlocks unlimited EGP tasks.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 4: The Liquidity Matrix (User Payouts)</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">1. Standard Payout (Monthly): </w:t></w:r><w:r><w:t xml:space="preserve">5% Fee.</w:t></w:r></w:p><w:p><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">2. Express Payout (Weekly): </w:t></w:r><w:r><w:t xml:space="preserve">10% Fee.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="300"/></w:pPr><w:r><w:rPr><w:b/><w:bCs/></w:rPr><w:t xml:space="preserve">3. Flash Payout (Instant): </w:t></w:r><w:r><w:t xml:space="preserve">20% Fee.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 5: Complete Task Template Registry</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Core Tasks: Video (T1/T2), Survey (T2), App Install (T2/T3), Quiz (T1), Social Media (T1).</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Premium/Physical Tasks: Photo (T3), Retail Visit (T3), Product Review (T3).</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="300"/></w:pPr><w:r><w:t xml:space="preserve">Enterprise Tasks: Mystery Shopping (T4), UGC Video (T4), Verified Lead Gen (T4).</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 6: Complete Task Template System Design Architecture</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="300"/></w:pPr><w:r><w:t xml:space="preserve">System defined by JSON workflows, granular fraud prevention (GPS, Watch Time, Pattern Detection), and multi-layer operational metrics.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 7: Ramadan 2026 Use Cases</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">1. Fresh / Edita / Juhayna / 57357 -&gt; Tier 1 Mass Awareness (Digital Surveys &amp; Videos).</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">2. WE / NBE / Etisalat / Remas Land -&gt; Tier 2 App Downloads &amp; Logic Surveys.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">3. B-Laban / Pepsi / Orange -&gt; Tier 3 GPS Store Visits &amp; Photo Audits.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="400"/></w:pPr><w:r><w:t xml:space="preserve">4. TMG / Palm Hills / Vodafone / Banque Misr -&gt; Tier 4 Verified Lead Gen &amp; Account Opening.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading1"/><w:spacing w:after="200" w:before="300"/></w:pPr><w:r><w:t xml:space="preserve">Part 8: 360-Degree Compliance &amp; Platform Policies</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:t xml:space="preserve">This section resolves edge cases and establishes the protective business rules for the TaskKash ecosystem.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">A. User Strike &amp; Penalty System</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">To guarantee the Zero-Fraud SLA for Tier 4 Advertisers, TaskKash strictly penalizes users submitting invalid data (e.g., submitting photos from a computer screen instead of live retail shelves).</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">• Strike 1: Warning + Task Rejected.</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">• Strike 2: Account temporarily locked for 7 days.</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:t xml:space="preserve">• Strike 3: Permanent Ban or Downgrade from &apos;Elite Field Agent&apos; back to &apos;Novice&apos;.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">B. Inactivity Churn (Tier Degradation)</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:t xml:space="preserve">User profiles degrade in value over time. If an &apos;Elite Field Agent&apos; (Level 3) does not continuously use the app for 6 months, their GPS behavioral data and income data become stagnant. They will automatically be downgraded to &apos;Verified Contributor&apos; (Level 2) and must complete a &apos;Profile Refresh Task&apos; to regain Elite status.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">C. Minimum Withdrawal Thresholds</w:t></w:r></w:p><w:p><w:pPr><w:spacing w:after="200"/></w:pPr><w:r><w:t xml:space="preserve">While the Liquidity Matrix decoupled payout speeds, a hard EGP minimum floor is enforced to avoid excessive banking/API micro-transaction fees. The minimum withdrawal amount is strictly set to 50.00 EGP.</w:t></w:r></w:p><w:p><w:pPr><w:pStyle w:val="Heading2"/></w:pPr><w:r><w:t xml:space="preserve">D. Pricing Inflation &amp; Dynamic Indexing</w:t></w:r></w:p><w:p><w:r><w:t xml:space="preserve">Given market fluctuations, all minimum Advertiser budgets and User rewards written in this constitution (based on $1 USD = 52 EGP) are subject to quarterly algorithmic re-indexing to ensure rewards remain viable motivators for the local population.</w:t></w:r></w:p><w:sectPr><w:pgSz w:w="11906" w:h="16838" w:orient="portrait"/><w:pgMar w:top="1440" w:right="1440" w:bottom="1440" w:left="1440" w:header="708" w:footer="708" w:gutter="0"/><w:pgNumType/><w:docGrid w:linePitch="360"/></w:sectPr></w:body></w:document>
